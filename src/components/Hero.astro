---
// Full-width hero with looping reel background — plays on mobile too now,
// using a separate lower-res/bitrate file (see public/hero-reel-mobile.mp4)
// so mobile never fetches the full desktop file. .hero-bg + the poster image
// remain the fallback shown while the video loads, or if autoplay is
// blocked outright (see the play().catch() below).
//
// The video source is picked in JS (below), not via <source media="">.
// iOS Safari has a long history of unreliably honoring the media attribute
// on <source> elements inside <video> — unlike <picture>, where it's solid.
// Setting .src directly is the robust, widely-recommended workaround, and
// since the element starts with no src/source at all, nothing is fetched
// until that script runs, so there's no risk of double-loading.
//
// Mobile keeps the original background-video structure (text overlaid on
// top, same as desktop) — just a shorter hero box with the video letterboxed
// via object-fit: contain instead of cover, so it keeps its full 16:9 frame
// with no cropping. See the mobile HERO rules in global.css.
---
<link rel="preload" as="image" href="/hero-poster.jpg" media="(max-width: 768px)" />
<section class="hero">
  <div class="hero-bg"></div>
  <video
    class="hero-video"
    id="heroVideo"
    autoplay muted loop playsinline
    preload="auto"
  ></video>
  <div class="hero-overlay"></div>
  <div class="hero-fade"></div>

  <div class="hero-content">
    <div class="hero-eyebrow">Filmmaker &nbsp;·&nbsp; Content Creator</div>
    <h1>Eliya Kapach</h1>
    <p class="hero-available"><span>[</span> Available worldwide <span>]</span></p>
    <div class="hero-buttons">
      <a href="#films" class="hero-btn primary">See Work</a>
      <a href="#contact" class="hero-btn">Let's Create</a>
    </div>
  </div>

  <div class="hero-border"></div>
</section>

<script>
  const video = document.getElementById('heroVideo') as HTMLVideoElement | null;
  if (video) {
    // Pick the source once, up front — deliberately not re-checked on
    // resize, matching how <source media=""> would have behaved anyway
    // (browsers only reconsider it on an explicit .load() call).
    const isMobile = window.matchMedia('(max-width: 768px)').matches;
    video.src = isMobile ? '/hero-reel-mobile.mp4' : '/HERO-REELcomp.mp4';

    const showVideo = () => video.classList.add('loaded');
    video.addEventListener('canplay', showVideo);
    video.addEventListener('loadeddata', showVideo);
    if (video.readyState >= 3) showVideo();
    video.play().catch(() => {
      document.addEventListener('touchstart', () => video.play(), { once: true });
    });
  }
</script>
