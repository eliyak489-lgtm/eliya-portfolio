---
// Homepage Instagram strip — plain local images linking out to the real
// post, no embed iframe and no Instagram chrome/branding. A card only
// renders if its image file actually exists in /public/instagram/; if none
// of the three do, the section renders nothing at all.
import fs from 'node:fs';
import { fileURLToPath } from 'node:url';
import { instagramPosts } from '../data/instagram.ts';
import { site } from '../data/site.ts';

const posts = instagramPosts
  .filter((post) => fs.existsSync(fileURLToPath(new URL(`../../public${post.image}`, import.meta.url))))
  .slice(0, 3);
---
{posts.length > 0 && (
  <section class="instagram-section" id="instagram">
    <div class="films-header">
      <div>
        <h2 class="section-title">Follow Along</h2>
      </div>
      <a href={site.instagramUrl} target="_blank" rel="noopener" class="hero-btn instagram-follow-btn">
        View more on Instagram
      </a>
    </div>

    <div class="instagram-grid">
      {posts.map((post) => (
        <a href={post.postUrl} target="_blank" rel="noopener" class="instagram-tile" aria-label={post.alt}>
          <img src={post.image} alt={post.alt} loading="lazy" />
        </a>
      ))}
    </div>
  </section>
)}
