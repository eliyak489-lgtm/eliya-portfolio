---
import { placeholders } from '../../data/placeholders.ts';
interface Props { items?: string[]; }
const { items = [] } = Astro.props;
---
<div class="cs-block">
  <h3 class="cs-block-label">Deliverables</h3>
  {items.length > 0 ? (
    <ul class="cs-deliverables-list">
      {items.map((item) => <li>{item}</li>)}
    </ul>
  ) : (
    <p class="cs-placeholder">{placeholders.deliverables}</p>
  )}
</div>
