---
interface Props { images?: string[]; alt: string; }
const { images = [], alt } = Astro.props;
---
{images.length > 0 && (
  <div class="cs-block">
    <h3 class="cs-block-label">Gallery</h3>
    <div class="cs-gallery-grid">
      {images.map((src) => <img src={src} alt={alt} loading="lazy" />)}
    </div>
  </div>
)}
