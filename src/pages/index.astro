---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import LogoTicker from '../components/LogoTicker.astro';
import FilmGrid from '../components/FilmGrid.astro';
import CategoryLinks from '../components/CategoryLinks.astro';
import Stats from '../components/Stats.astro';
// Testimonials temporarily disabled — data/testimonials.ts only has
// placeholder quotes. Re-enable this import + <Testimonials /> below once
// real client testimonials are added there.
// import Testimonials from '../components/Testimonials.astro';
import FAQ from '../components/FAQ.astro';
import InstagramPreview from '../components/InstagramPreview.astro';
import ContactForm from '../components/ContactForm.astro';
import FinalCTA from '../components/FinalCTA.astro';
import { projects } from '../data/projects.ts';

// Homepage "Selected Work" only shows real, existing content — placeholder
// (coming soon) projects appear on /work and their category page instead.
const homepageProjects = projects.filter((p) => !p.placeholder);
---
<BaseLayout>
  <Hero />
  <FilmGrid items={homepageProjects} />
  <LogoTicker />
  <CategoryLinks />
  <Stats />
  <About />
  {/* <Testimonials /> — see disabled import above */}
  <FAQ />
  <InstagramPreview />
  <ContactForm />
  <FinalCTA />
</BaseLayout>
